# Produksi: Supabase Postgres — pakai Transaction Pooler (port 6543) untuk Vercel.
# Dashboard Supabase → Connect → Transaction pooler → salin URI.
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
# Dev lokal tanpa install Postgres (PGlite in-process, migrasi otomatis):
# DATABASE_URL=pglite://./.pglite

# Wajib. Buat baru: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=

# Google AI Studio. Kosongkan untuk mode fallback offline.
GEMINI_API_KEY=

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
